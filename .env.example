# ===========================================
# SSO-VAULT Environment Configuration
# ===========================================

# --- Domain / Network ---
DOMAIN=localhost

# --- Keycloak (SSO) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KC_HOSTNAME=sso.localhost
KC_HTTP_PORT=8080

# --- SQL Server (External DB for Keycloak) ---
MSSQL_HOST=host.docker.internal
MSSQL_PORT=1433
MSSQL_DB=keycloak
MSSQL_USER=sa
MSSQL_PASSWORD=your_mssql_password

# --- HashiCorp Vault ---
VAULT_DEV_ROOT_TOKEN_ID=your_vault_root_token
VAULT_ADDR=http://vault:8200
VAULT_HOSTNAME=vault.localhost

# --- Traefik ---
TRAEFIK_DASHBOARD_HOSTNAME=traefik.localhost
